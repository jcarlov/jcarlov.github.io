@unpublished{velezlebron2026sugarrush,
  title     = {Sugar Rush: The Effect of Foreign Direct Investment in Colonial Puerto Rico (1898-1952)},
  author    = {Vélez Lebrón, Jeancarlo},
  year      = {2026},
  note      = {Job Market Paper. Work in Progress},
  abstract  = {The economic literature on colonial institutions relies primarily on aggregate outcomes measured far from the historical period of interest. Yet the historical record of plantation capitalism consistently emphasizes exploitation and displacement, while recent economic studies tend to find positive aggregate effects. This paper leverages Puerto Rico's full-count censuses (1910--1950) and a novel firm-level panel to study distributional and short-run effects during the period when the sugar industry was actively operating. The coexistence of U.S.-owned and locally owned mills under the same colonial policy environment makes it possible to ask whether the origin of capital---not just colonial policy---shaped outcomes for surrounding communities.},
  selected  = {true}
}

@mastersthesis{velezlebron2020china,
  title     = {China's Evolving Role in Asian Trade: A Network Approach},
  author    = {Vélez Lebrón, Jeancarlo},
  year      = {2020},
  school    = {Universidad de Puerto Rico, Recinto Río Piedras},
  note      = {MA Thesis},
  abstract  = {In this paper, network analysis is used to examine the changing role that China has played in the years 1995, 2005, and 2014. A network is constructed from a World Input-Output Matrix consisting of 43 countries and 56 industries. This matrix is transformed into a technology matrix where a filter is used to turn this matrix into a binary matrix. This matrix, in turn, is used to form a unweighted and directed network where each vertex represents a country and each edge represents a significant commercial relation that exceed the world average. Network centrality measures such as indegree, outdegree, betweeness centrality, hub index, and authority index are derived from this network and used to trace the role that China, Japan, South Korea, and Taiwan have played in World Trade, and see if there is evidence of interaction between these. Of the network measures used in this unweighted matrix, it is found that export-related measures show a strong positive correlation with GDP and import related measures have a negative correlation with GDP. It is observed that China has a large increase in all centrality measures across these years, while the centrality measures of the other East Asian nations remain largely unchanged. This, in conjunction with the increase in density and diameter of the World Trade Network as a whole, lead us to believe that even though China has made huge gains from trade through an export-led approach in the preceding decades with no evidence of displacement or ``crowding out'' of other developed economies in the East Asian region.}
}

@unpublished{bobonis2026management,
  title     = {Improving and Sustaining Management Practices in Public Schools: Evidence from Puerto Rico},
  author    = {Bobonis, Gustavo and González-Navarro, Marco and Scur, Daniela and Vélez Lebrón, Jeancarlo},
  year      = {2026},
  note      = {Work in Progress},
  abstract  = {We study whether a large-scale management training program for public school principals can improve school management quality and student achievement in Puerto Rico. In a randomized controlled trial covering approximately 845 public schools across the island, we evaluate the effects of an intensive professional development program providing training, workshops, and personalized coaching on key management practices. The staggered design allows us to estimate both short- and medium-run treatment effects, addressing whether management training impacts can be sustained over time.},
  selected  = {true}
}
